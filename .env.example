# Soft Floyd — environment variables
# Copy to .env and fill in the values you need.
# All keys are optional unless noted. Prefix: COACH_

# ── Phase 2: LLM & embeddings ─────────────────────────────────────────────────
COACH_OPENAI_API_KEY=sk-...          # required for coach (gpt-4.1-mini) and embeddings (RAG)

# ── Training ──────────────────────────────────────────────────────────────────
COACH_LTHR=165                       # lactate threshold HR (bpm); drives zone calculations

# ── Poller ────────────────────────────────────────────────────────────────────
COACH_POLL_INTERVAL_MINUTES=10       # how often to check Garmin Connect for new rides

# ── Phase 3: frontend serving ─────────────────────────────────────────────────
COACH_SERVE_FRONTEND=0               # set to 1 to serve built React app from FastAPI

# ── Logging ───────────────────────────────────────────────────────────────────
COACH_LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR

# ── Paths (defaults are usually fine) ─────────────────────────────────────────
# COACH_DB_PATH=data/trainer.db
# COACH_FIT_DIR=data/fit
# COACH_GARTH_TOKEN_PATH=~/.coach/garth.json
